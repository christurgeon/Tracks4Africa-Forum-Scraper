FORUM_USERNAME=your_username
FORUM_PASSWORD=your_password

# Cloudflare clearance cookie — required for search.php to work.
# DevTools → Application (Chrome) / Storage (Safari) → Cookies → www.4x4community.co.za → cf_clearance
CF_CLEARANCE=

# Must match the User-Agent of the browser that generated CF_CLEARANCE.
# DevTools → Network → click any request → Headers → User-Agent
FORUM_USER_AGENT=
